# ---------------------------------------------------------------------------
# Copy this file to ".env.local" and fill in the values from the Azure Portal.
# NEVER commit .env.local. These keys must stay server-side only.
# See AZURE_SETUP.md for step-by-step instructions on getting each value.
# ---------------------------------------------------------------------------

# --- Azure AI Vision (the required AI feature) ---
# Resource: "Computer Vision" / "Azure AI Vision". From the resource's
# "Keys and Endpoint" blade.
VISION_ENDPOINT=https://YOUR-vision-resource.cognitiveservices.azure.com/
VISION_KEY=your-vision-key-here
# Features to request. caption needs a supported region (e.g. eastus, westus2).
# Safe everywhere: "tags,read". Recommended: "caption,tags,read".
VISION_FEATURES=caption,tags,read

# --- Azure Blob Storage (persistent data) ---
# From the Storage account's "Access keys" blade. Optional for local dev:
# if unset, images are served from /public/signs and uploads are disabled.
AZURE_STORAGE_CONNECTION_STRING=
# Container that holds the sign images + uploads (created automatically).
AZURE_STORAGE_CONTAINER=signs
# Public base URL of the images container, used by the gallery in production.
# Example: https://YOURACCOUNT.blob.core.windows.net/signs
NEXT_PUBLIC_BLOB_BASE_URL=
